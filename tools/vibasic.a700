; vibasic.a700
; ==========================================================================
; VIBASIC — a single-user line-number BASIC for the RDC-700.
; Boots from RIM paper tape; runs in supervisor mode.
;
; INCREMENT 1 — Foundation (this file):
;   - Boot, IRQL setup, physical memory detection (see monitor.a700)
;   - Interrupt-driven buffered console I/O (adapted from echo.a700)
;   - Integer print (io_putn), string print (io_puts), line input (io_gets)
;   - A READY loop that echoes typed input (proves the I/O path end-to-end)
;
; Later increments add the tokenizer, line storage, expression evaluator,
; statements, and the remaining data types per VIBASIC_PLAN.txt.
;
; Conventions:
;   Leaf I/O helpers use callr/retr.  Arguments in x0..x3; integer return
;   in ac.  Routines that call others save their return address explicitly
;   (callr clobbers lr) or use the hardware stack.
;
; Device assumptions (match the emulator's main()):
;   TTY console at device #030 (octal 060 = 48), IRQ level 10, vector @ 20.
; ==========================================================================


; ==========================================================================
; Interrupt / exception vector table
; ==========================================================================

            origin      0

exc_vec:    dw          exc_hdlr, 0     ; level 0: exceptions

            origin      20              ; level 10: TTY interrupt (2 x 10)

tty_vec:    dw          tty_intr, 0


; ==========================================================================
; Boot
; ==========================================================================

            origin      1024

start:      xorr        ac, ac
            ldctl       psw1, .fgcw     ; IRQL = 15 (so lmwait is wakeable)
            ldea        sp, .topstk     ; supervisor stack

            callr       .mem_det        ; detect RAM -> memtop / varbot / progend
            callr       .con_init       ; TTY config + clear interrupt

            ldea        ac, .strheap     ; init string heap
            st          ac, .strnext
            ldea        ac, .strendl
            st          ac, .strend

            ldea        x0, .msg_ban    ; "VIBASIC V0.1"
            callr       .io_puts
            callr       .io_crlf
            ld          ac, .memtop     ; free word count
            callr       .io_putn
            ldea        x0, .msg_free   ; " WORDS FREE"
            callr       .io_puts
            callr       .io_crlf

            ldea        x0, .msg_rdy     ; initial "READY."
            callr       .io_puts
            callr       .io_crlf

; ----- READY loop ---------------------------------------------------------
; Read a line.  If it begins with a digit it is a program edit (store or
; delete a numbered line); otherwise it is a direct command: tokenize and
; execute, then print READY.
ready:      ldea        sp, .topstk      ; reset stack each command
            ldea        x0, .linebuf
            ld          x1, .linemax
            callr       .io_gets
            st          ac, .linelen

            ldea        x0, .linebuf     ; first char a digit?
            ld          ac, (x0)
            callr       .id_digit
            movr.rz     ac, ac           ; skip jmp when digit
            jmp         .rdy_dir

            calls       .do_edit         ; program line edit (silent)
            jmp         .ready

rdy_dir:    ldea        x0, .linebuf     ; tokenize the whole line
            ld          x1, .linelen
            calls       .tok_line
            ldea        x0, .tokbuf
            calls       .par_exec
            ldea        x0, .msg_rdy
            callr       .io_puts
            callr       .io_crlf
            jmp         .ready


; ==========================================================================
; Memory detection — probe upward until X_MEMX (see monitor.a700)
; ==========================================================================
; Installs a temporary level-0 handler (md_done), walks memory with an
; auto-increment indirect pointer, and on the bounds fault records the first
; nonexistent address.  memtop = RAM size; varbot = memtop; progend = progbase.

mem_det:    ldea        ac, .md_done    ; temporary exception vector
            st          ac, .exc_vec

            ldea        x6, .progbase    ; probe pointer: base = progbase,
            or          x6, .incptr      ;   bit35=auto, mode=inc, step=1
            st          x6, .md_ptr

md_loop:    ld          ac, @.md_ptr     ; touch M[*md_ptr]; post-increment ptr
            jmp         .md_loop         ; X_MEMX exits via md_done

md_done:    ldctl       psw1, .fgcw      ; exception dropped us to IRQL 0
            ld          ac, .md_ptr      ; pointer = step bits | first bad addr
            and         ac, .admask      ; keep 27-bit address field
            st          ac, .memtop
            st          ac, .varbot
            ldea        ac, .progbase
            st          ac, .progend
            ldea        ac, .exc_hdlr    ; restore real exception handler
            st          ac, .exc_vec
            retr

incptr:     dw          0401000000000    ; auto-increment-by-1 indirect pointer
admask:     dw          #7FFFFFF         ; 27-bit address mask
md_ptr:     bss         1


; ==========================================================================
; Exception handler (level 0) — for this increment, just halt cleanly.
; (A later increment maps faults to BASIC error codes and unwinds to READY.)
; ==========================================================================

exc_hdlr:   hlt


; ==========================================================================
; Console I/O layer (interrupt-driven; adapted from echo.a700)
; ==========================================================================

tty_intr:   st          ac, .th_ac
            st          x2, .th_x2
            st          x3, .th_x3

            ld          ac, .out_actv
            movr.rz     ac, ac          ; skip jmp if output active
            jmp         .ti_inp

            ld          x2, .out_ptr
            ld          x3, .out_cnt
            incr.rn     x3, x3          ; skip jmp if count reached 0
            jmp         .ti_tx

            nioc        #030            ; output complete
            st          x3, .out_cnt
            xorr        ac, ac
            st          .out_actv
            incr        ac, ac
            st          .out_done
            jmp         .ti_ret

ti_tx:      ld          ac, (x2)
            incr        x2, x2
            st          x2, .out_ptr
            st          x3, .out_cnt
            wios        ac, 0, #030
            jmp         .ti_ret

ti_inp:     nioc        #030            ; input event
            xorr        ac, ac
            incr        ac, ac
            st          .inp_rdy

ti_ret:     ld          x3, .th_x3
            ld          x2, .th_x2
            ld          ac, .th_ac
            reti

; --- con_init -------------------------------------------------------------
con_init:   ld          ac, .ttyconf
            wio         ac, 1, #030
            nioc        #030
            retr

; --- io_putl: send word-per-char buffer (x0=addr, x1=count); blocks --------
; Clobbers ac, x0, x1, x3, x4, x5.  Returns via retr.
io_putl:    movr.rz     x1, x1          ; skip retr if count != 0
            retr
            ld          x4, (x0)         ; first char
            incr        x0, x0
            st          x0, .out_ptr
            ngtr        x1, x3
            st          x3, .out_cnt
            xorr        ac, ac
            st          .out_done
            incr        ac, ac
            st          .out_actv
            movr        x4, ac
            wios        ac, 0, #030      ; send first char; starts the chain
iputl_w:    ldmask      .nomask          ; race-free wait for completion
            ld          .out_done
            movr.rz     ac, ac           ; skip jmp if done
            jmp         .iputl_lm
            retr
iputl_lm:   lmwait      .irqmask
            jmp         .iputl_w

; --- io_putc: output single char in ac ------------------------------------
; Tail-calls io_putl, which returns to io_putc's caller.
io_putc:    st          ac, .onechar
            ldea        x0, .onechar
            ldea        x1, 1
            jmp         .io_putl
onechar:    bss         1

; --- io_crlf: output CR LF ------------------------------------------------
io_crlf:    ldea        x0, .crlfbuf
            ldea        x1, 2
            jmp         .io_putl

; --- io_puts: output a dsn string (x0 = pointer to count word) ------------
; Expands the packed string into outexp, then sends it.  Returns via retr.
io_puts:    ld          x1, (x0)         ; char count
            st          x1, .putsn       ; remember it for the send
            movr.rz     x1, x1           ; skip retr if nonzero
            retr
            ngtr        x1, x5           ; x5 = -count
            ldea        x4, .outexp      ; write pointer
iputs_l:    incldb      ac, x0, 7        ; next 7-bit char from dsn body
            st          ac, (x4)
            incr        x4, x4
            incr.rn     x5, x5           ; skip jmp when expanded all chars
            jmp         .iputs_l
            ld          x1, .putsn       ; send the expanded buffer
            ldea        x0, .outexp
            jmp         .io_putl
putsn:      bss         1

; --- io_putn: output signed decimal integer in ac -------------------------
; Pushes digits on the hardware stack, then prints them.  Returns via retr.
io_putn:    st          lr, .putn_lr
            st          ac, .putn_v
            movr.rz     ac, ac           ; skip jmp when value != 0
            jmp         .putn_zero       ; value == 0: print "0"
putn_nz:    ld          ac, .putn_v
            and         ac, .signbit     ; bit 35 set => negative
            movr.rz     ac, ac           ; skip jmp when negative
            jmp         .putn_abs
            jmp         .putn_neg
putn_neg:   ldea        ac, 45           ; "-"
            callr       .io_putc
            ld          ac, .putn_v
            ngtr        ac, ac
            st          ac, .putn_v
putn_abs:   xorr        ac, ac
            st          ac, .putn_n      ; digit count = 0
putn_dl:    ld          ac, .putn_v
            div         .tenw            ; mq = v/10, xy = v%10
            push        xy               ; save remainder digit
            ld          ac, .putn_n
            incr        ac, ac
            st          ac, .putn_n
            movr        mq, ac           ; ac = quotient
            st          ac, .putn_v
            movr.rn     mq, mq           ; skip jmp when quotient == 0 (done)
            jmp         .putn_dl         ; quotient != 0: extract next digit
putn_pr:    ld          ac, .putn_n
            ngtr        ac, ac
            st          ac, .putn_n      ; putn_n = -count
putn_pl:    pop         ac               ; digit 0..9
            addi        ac, ac, 48
            callr       .io_putc
            ld          ac, .putn_n
            incr        ac, ac
            st          ac, .putn_n
            movr.rn     ac, ac           ; skip jmp when count reaches 0
            jmp         .putn_pl
            ld          lr, .putn_lr
            retr
putn_zero:  ldea        ac, 48           ; "0"
            callr       .io_putc
            ld          lr, .putn_lr
            retr

tenw:       dw          10
zerow:      dw          0
putn_v:     bss         1
putn_n:     bss         1
putn_lr:    bss         1

; --- io_gets: read one line, word-per-char (x0=buf, x1=max) -> ac=count ----
io_gets:    st          x0, .gets_buf
            st          x1, .gets_max
            xorr        ac, ac
            st          .inp_rdy
            st          .gilen
ig_wait:    ldmask      .nomask
            ld          .inp_rdy
            movr.rz     ac, ac           ; skip jmp if ready
            jmp         .ig_lm
            ldmask      .irqmask
            jmp         .ig_read
ig_lm:      lmwait      .irqmask
            jmp         .ig_wait
ig_read:    ld          x4, .gets_buf    ; write pointer
            ld          ac, .gets_max
            ngtr        ac, x5           ; x5 = -max
ig_loop:    rio         ac, 2, #030      ; receive fill count
            movr.rz     ac, ac           ; skip jmp if data available
            jmp         .ig_done
            rio         ac, 0, #030      ; pop byte
            subin.rn    ac, ac, 10       ; skip store-branch if LF
            jmp         .ig_store
            st          ac, (x4)         ; store LF and finish
            ld          ac, .gilen
            incr        ac, ac
            st          .gilen
            jmp         .ig_done
ig_store:   st          ac, (x4)
            incr        x4, x4
            ld          ac, .gilen
            incr        ac, ac
            st          .gilen
            incr.rn     x5, x5           ; skip jmp if buffer full
            jmp         .ig_loop
ig_done:    ld          ac, .gilen
            retr

gets_buf:   bss         1
gets_max:   bss         1
gilen:      bss         1


; ==========================================================================
; Character classification (leaf; callr/retr).  Each takes a char in ac and
; returns ac = 1/0.  All clobber x6, x7 (callers keep state elsewhere).
; ==========================================================================

id_digit:   st          ac, .cltmp
            ld          x6, .cltmp
            ld          x7, .c48
            cmpge       x6, x7           ; x6 >= '0' ?
            jmp         .idg_hi
            jmp         .idg_no
idg_hi:     ld          x7, .c57
            cmple       x6, x7           ; x6 <= '9' ?
            jmp         .idg_yes
            jmp         .idg_no
idg_yes:    ldea        ac, 1
            retr
idg_no:     xorr        ac, ac
            retr

id_alpha:   st          ac, .cltmp
            ld          x6, .cltmp
            ld          x7, .c65
            cmpge       x6, x7           ; >= 'A' ?
            jmp         .ida_uc
            jmp         .ida_no
ida_uc:     ld          x7, .c90
            cmple       x6, x7           ; <= 'Z' ?
            jmp         .ida_yes
            ld          x7, .c97
            cmpge       x6, x7           ; >= 'a' ?
            jmp         .ida_lc
            jmp         .ida_no
ida_lc:     ld          x7, .c122
            cmple       x6, x7           ; <= 'z' ?
            jmp         .ida_yes
            jmp         .ida_no
ida_yes:    ldea        ac, 1
            retr
ida_no:     xorr        ac, ac
            retr

id_alnum:   st          lr, .alnlr
            st          ac, .alnch
            callr       .id_digit
            movr.rz     ac, ac           ; skip next when digit
            jmp         .aln_alp
            ldea        ac, 1
            ld          lr, .alnlr
            retr
aln_alp:    ld          ac, .alnch
            callr       .id_alpha
            ld          lr, .alnlr
            retr

to_upper:   st          ac, .cltmp
            ld          x6, .cltmp
            ld          x7, .c97
            cmpge       x6, x7           ; >= 'a' ?
            jmp         .tu_hi
            retr
tu_hi:      ld          x7, .c122
            cmple       x6, x7           ; <= 'z' ?
            jmp         .tu_lo
            retr
tu_lo:      ld          ac, .cltmp
            addi        ac, ac, -32
            retr

cltmp:      bss         1
alnch:      bss         1
alnlr:      bss         1
c48:        dw          48
c57:        dw          57
c65:        dw          65
c90:        dw          90
c97:        dw          97
c122:       dw          122


; ==========================================================================
; emit_packed — append a packed (dsn-style) token to tokbuf.
;   x0 = tag word (e.g. TKN_STR or TKN_VAR base)
;   x1 = source pointer (word-per-char)
;   x2 = char count
; Emits  (tag | count)  then  ceil(count/5)  packed 7-bit body words.
; Updates tk_dst.  No console I/O, so x-registers are safe here.
; ==========================================================================

emit_packed:save        x4, x5, x6, x7
            st          x1, .ep_src
            st          x2, .ep_cnt
            movr        x2, ac
            bisr        x0, ac           ; ac = count | tag
            ld          x6, .tk_dst
            st          ac, (x6)         ; store tag|count word
            st          x6, .ep_tagad
            ld          ac, .ep_cnt      ; nbody = ceil(count/5)
            addi        ac, ac, 4
            div         .fivew
            movr        mq, ac
            st          ac, .ep_nbody
            ld          x4, .ep_tagad    ; zero the body words (incstb only ORs)
            incr        x4, x4
            ld          x5, .ep_nbody
            ngtr        x5, x5
            movr.rz     x5, x5           ; skip when nbody == 0
            jmp         .ep_zd
ep_zlp:     xorr        ac, ac
            st          ac, (x4)
            incr        x4, x4
            incr.rn     x5, x5
            jmp         .ep_zlp
ep_zd:      ld          x7, .ep_tagad    ; BX pointer = tag word addr (shift 0)
            ld          x1, .ep_src
            ld          x5, .ep_cnt
            ngtr        x5, x5
            movr.rz     x5, x5           ; skip when count == 0
            jmp         .ep_fin
ep_lp:      ld          ac, (x1)
            incr        x1, x1
            incstb      ac, x7, 7        ; pack into body (advances x7)
            incr.rn     x5, x5
            jmp         .ep_lp
ep_fin:     ld          ac, .ep_tagad    ; tk_dst = tagad + 1 + nbody
            addi        ac, ac, 1
            add         ac, .ep_nbody
            st          ac, .tk_dst
            rets

ep_src:     bss         1
ep_cnt:     bss         1
ep_tagad:   bss         1
ep_nbody:   bss         1
fivew:      dw          5


; ==========================================================================
; tok_emit1 — append a single token word in ac to tokbuf (leaf).
; ==========================================================================
tok_emit1:  ld          x6, .tk_dst
            st          ac, (x6)
            incr        x6, x6
            st          x6, .tk_dst
            retr


; ==========================================================================
; name_eq — compare scanned identifier to a keyword dsn string.
;   x0 = idbuf (word-per-char)   x1 = id length   x2 = dsn string pointer
; Returns ac = 1 if equal, else 0.
; ==========================================================================
name_eq:    save        x4, x5, x6, x7
            ld          ac, (x2)         ; dsn char count
            st          x1, .ne_len
            sub         ac, .ne_len      ; count - len
            movr.rn     ac, ac           ; skip jmp when lengths equal
            jmp         .ne_no
            movr        x0, x4           ; idbuf pointer
            movr        x2, x5           ; dsn BX pointer (count word addr)
            ngtr        x1, x6           ; x6 = -len
            movr.rn     x6, x6           ; skip jmp when len == 0
            jmp         .ne_cmp
            ldea        ac, 1            ; len 0 -> equal
            rets
ne_cmp:     incldb      ac, x5, 7        ; next dsn char (advances x5)
            ld          x7, (x4)         ; id char
            incr        x4, x4
            st          x7, .ne_ch
            sub         ac, .ne_ch       ; dsnchar - idchar
            movr.rn     ac, ac           ; skip jmp when equal
            jmp         .ne_no
            incr.rn     x6, x6           ; skip jmp when all compared
            jmp         .ne_cmp
            ldea        ac, 1
            rets
ne_no:      xorr        ac, ac
            rets

ne_len:     bss         1
ne_ch:      bss         1


; ==========================================================================
; tok_number — parse a decimal integer at tk_src; emit TKN_INT + value.
; ==========================================================================
tok_number: save        x4, x5
            ld          x4, .tk_src
            xorr        x5, x5           ; accumulated value
tn_lp:      ld          x6, .tk_send
            cmplt       x4, x6           ; src < send ?
            jmp         .tn_chk
            jmp         .tn_emit
tn_chk:     ld          ac, (x4)
            callr       .id_digit        ; clobbers x6,x7 (x4,x5 safe)
            movr.rz     ac, ac           ; skip jmp when digit
            jmp         .tn_emit
            ld          ac, (x4)         ; digit char
            addi        ac, ac, -48
            st          ac, .tn_dig
            movr        x5, mq           ; mq = value
            mul         .tenw            ; ac = value * 10 (low word)
            add         ac, .tn_dig      ; + digit
            movr        ac, x5           ; value = ac
            incr        x4, x4
            jmp         .tn_lp
tn_emit:    st          x4, .tk_src
            ld          ac, .tknint
            callr       .tok_emit1       ; emit tag
            movr        x5, ac
            callr       .tok_emit1       ; emit value
            rets

tn_dig:     bss         1


; ==========================================================================
; tok_string — parse "..." at tk_src; emit TKN_STR + packed chars.
; ==========================================================================
tok_string: save        x4, x5
            ld          x4, .tk_src
            incr        x4, x4           ; skip opening quote
            movr        x4, x5           ; x5 = start of string chars
            xorr        ac, ac
            st          .ts_cnt
ts_lp:      ld          x6, .tk_send
            cmplt       x4, x6           ; src < send ?
            jmp         .ts_chk
            jmp         .ts_end
ts_chk:     ld          ac, (x4)
            subin.rn    ac, ac, 34       ; closing quote?
            jmp         .ts_more
            jmp         .ts_end
ts_more:    incr        x4, x4
            ld          ac, .ts_cnt
            incr        ac, ac
            st          .ts_cnt
            jmp         .ts_lp
ts_end:     ld          ac, .tknstr      ; tag
            movr        ac, x0
            movr        x5, x1           ; source ptr
            ld          x2, .ts_cnt      ; count
            calls       .emit_packed
            ; advance src past closing quote (if present)
            ld          x4, .tk_src      ; (unchanged; recompute end)
            ld          x4, .ts_cnt
            ld          x5, .tk_src
            incr        x5, x5           ; past opening quote
            addr        x4, x5           ; x5 = first char + count = closing quote
            incr        x5, x5           ; past closing quote
            st          x5, .tk_src
            rets

ts_cnt:     bss         1


; ==========================================================================
; tok_ident — parse an identifier (keyword or variable) at tk_src.
; ==========================================================================
tok_ident:  save        x4, x5
            ld          x4, .tk_src
            xorr        x5, x5           ; id length
ti_scan:    ld          x6, .tk_send
            cmplt       x4, x6           ; src < send ?
            jmp         .ti_c
            jmp         .ti_done
ti_c:       ld          ac, (x4)
            callr       .id_alnum        ; clobbers x6,x7 (x4,x5 safe)
            movr.rz     ac, ac           ; skip jmp when alnum
            jmp         .ti_done
            ld          ac, (x4)
            callr       .to_upper
            ldea        x6, .idbuf
            addr        x5, x6           ; idbuf + len
            st          ac, (x6)
            incr        x5, x5
            ld          x6, .idmax
            cmplt       x5, x6           ; len < 10 ? keep scanning
            jmp         .ti_adv
            jmp         .ti_done
ti_adv:     incr        x4, x4
            jmp         .ti_scan
ti_done:    st          x4, .tk_src
            st          x5, .idlen
            ; keyword lookup
            ldea        x6, .kw_tab
ti_kw:      ld          ac, (x6)         ; dsn ptr (0 = end)
            movr.rz     ac, ac           ; skip jmp when entry present
            jmp         .ti_var
            ldea        x0, .idbuf
            ld          x1, .idlen
            ld          x2, (x6)
            st          x6, .ti_save
            calls       .name_eq
            ld          x6, .ti_save
            movr.rz     ac, ac           ; skip jmp when match
            jmp         .ti_knext
            ld          ac, 1(x6)         ; matched: emit tag word
            callr       .tok_emit1
            rets
ti_knext:   addi        x6, x6, 2
            jmp         .ti_kw
ti_var:     ld          ac, .tknvar      ; variable: emit TKN_VAR + packed name
            movr        ac, x0
            ldea        x1, .idbuf
            ld          x2, .idlen
            calls       .emit_packed
            rets

ti_save:    bss         1
idmax:      dw          10
idbuf:      bss         11
idlen:      bss         1


; ==========================================================================
; tok_op — parse an operator at tk_src; emit its token.  ac = 0 ok / 1 error.
; ==========================================================================
tok_op:     save        x4
            ld          x4, .tk_src
            ld          ac, (x4)
            st          ac, .op_ch
            subin.rn    ac, ac, 60       ; '<' ?
            jmp         .op_nlt
            jmp         .op_lt
op_nlt:     ld          ac, .op_ch
            subin.rn    ac, ac, 62       ; '>' ?
            jmp         .op_single
            jmp         .op_gt
op_lt:      ld          x4, .tk_src
            ld          ac, 1(x4)
            st          ac, .op_ch2
            subin.rn    ac, ac, 61       ; '<=' ?
            jmp         .lt_nE
            ld          ac, .tknle
            jmp         .op_emit2
lt_nE:      ld          ac, .op_ch2
            subin.rn    ac, ac, 62       ; '<>' ?
            jmp         .lt_nNE
            ld          ac, .tknne
            jmp         .op_emit2
lt_nNE:     ld          ac, .tknlt
            jmp         .op_emit1
op_gt:      ld          x4, .tk_src
            ld          ac, 1(x4)
            subin.rn    ac, ac, 61       ; '>=' ?
            jmp         .gt_nE
            ld          ac, .tknge
            jmp         .op_emit2
gt_nE:      ld          ac, .tkngt
            jmp         .op_emit1
op_single:  ldea        x4, .optab
ops_lp:     ld          ac, (x4)         ; table char (0 = end)
            movr.rz     ac, ac
            jmp         .op_bad
            ld          ac, .op_ch
            sub         ac, (x4)
            movr.rn     ac, ac           ; skip jmp when char matches
            jmp         .ops_next
            ld          ac, 1(x4)         ; emit tag word
            callr       .tok_emit1
            ld          x4, .tk_src
            incr        x4, x4
            st          x4, .tk_src
            xorr        ac, ac
            rets
ops_next:   addi        x4, x4, 2
            jmp         .ops_lp
op_bad:     ldea        ac, 1            ; unknown char
            rets
op_emit2:   callr       .tok_emit1
            ld          x4, .tk_src
            addi        x4, x4, 2
            st          x4, .tk_src
            xorr        ac, ac
            rets
op_emit1:   callr       .tok_emit1
            ld          x4, .tk_src
            incr        x4, x4
            st          x4, .tk_src
            xorr        ac, ac
            rets

op_ch:      bss         1
op_ch2:     bss         1


; ==========================================================================
; tok_sksp — advance tk_src past spaces (leaf).
; ==========================================================================
tok_sksp:   ld          x6, .tk_src
            ld          x7, .tk_send
ts2_lp:     cmplt       x6, x7           ; src < send ?
            jmp         .ts2_chk
            retr
ts2_chk:    ld          ac, (x6)
            subin.rn    ac, ac, 32       ; space ?
            jmp         .ts2_done
            incr        x6, x6
            st          x6, .tk_src
            jmp         .ts2_lp
ts2_done:   retr


; ==========================================================================
; tok_line — tokenize x1 chars starting at x0 into tokbuf, ending TKN_EOL.
; Returns ac = 0 on success, 1 on error.
; ==========================================================================
tok_line:   save        x4, x5
            st          x0, .tk_src
            movr        x0, x4
            addr        x1, x4           ; start + count
            st          x4, .tk_send
            ldea        x4, .tokbuf
            st          x4, .tk_dst
tl_lp:      callr       .tok_sksp
            ld          x4, .tk_src
            ld          x5, .tk_send
            cmplt       x4, x5           ; more chars ?
            jmp         .tl_more
            jmp         .tl_eol
tl_more:    ld          ac, (x4)
            st          ac, .tk_ch
            subin.rn    ac, ac, 13       ; CR ?
            jmp         .tl_n13
            jmp         .tl_eol
tl_n13:     ld          ac, .tk_ch
            subin.rn    ac, ac, 10       ; LF ?
            jmp         .tl_n10
            jmp         .tl_eol
tl_n10:     ld          ac, .tk_ch
            callr       .id_digit
            movr.rz     ac, ac           ; skip jmp when digit
            jmp         .tl_nd
            calls       .tok_number
            jmp         .tl_lp
tl_nd:      ld          ac, .tk_ch
            callr       .id_alpha
            movr.rz     ac, ac           ; skip jmp when alpha
            jmp         .tl_na
            calls       .tok_ident
            jmp         .tl_lp
tl_na:      ld          ac, .tk_ch
            subin.rn    ac, ac, 34       ; quote ?
            jmp         .tl_nq
            calls       .tok_string
            jmp         .tl_lp
tl_nq:      calls       .tok_op
            movr.rn     ac, ac           ; skip jmp when ok (ac == 0)
            jmp         .tl_err
            jmp         .tl_lp
tl_eol:     xorr        ac, ac
            callr       .tok_emit1       ; TKN_EOL
            xorr        ac, ac
            rets
tl_err:     ldea        ac, 1
            rets

tk_ch:      bss         1


; ==========================================================================
; detok — de-tokenize the token list at x0 to the console.
; (Stage A: used as the temporary par_exec body to verify the tokenizer.)
; ==========================================================================
detok:      save        x4
            st          x0, .dt_ptr      ; token pointer kept in memory (io clobbers x4)
dt_lp:      ld          x4, .dt_ptr
            ld          ac, (x4)
            movr.rz     ac, ac           ; skip jmp when word != 0
            jmp         .dt_done
            st          ac, .dt_word
            and         ac, .tagmask
            st          ac, .dt_tag
            sub         ac, .tknint
            movr.rn     ac, ac           ; INT ?
            jmp         .dt_nI
            ld          x4, .dt_ptr      ; INT: value at ptr+1
            incr        x4, x4
            ld          ac, (x4)
            incr        x4, x4
            st          x4, .dt_ptr
            callr       .io_putn
            jmp         .dt_sp
dt_nI:      ld          ac, .dt_tag
            sub         ac, .tknvar
            movr.rn     ac, ac           ; VAR ?
            jmp         .dt_nV
            calls       .dt_packed       ; print name body
            jmp         .dt_sp
dt_nV:      ld          ac, .dt_tag
            sub         ac, .tknstr
            movr.rn     ac, ac           ; STR ?
            jmp         .dt_nS
            ldea        ac, 34           ; opening quote
            callr       .io_putc
            calls       .dt_packed       ; print string body
            ldea        ac, 34           ; closing quote
            callr       .io_putc
            jmp         .dt_sp
dt_nS:      ld          ac, .dt_word     ; operator or keyword
            calls       .rev_print
            ld          x4, .dt_ptr
            incr        x4, x4
            st          x4, .dt_ptr
            jmp         .dt_sp
dt_sp:      ldea        ac, 32           ; space between tokens
            callr       .io_putc
            jmp         .dt_lp
dt_done:    callr       .io_crlf
            rets

; dt_packed — print the count packed chars of the token at dt_ptr, then
; advance dt_ptr past the token.  dt_word must hold the tag|count word.
dt_packed:  save        x5
            ld          ac, .dt_word
            and         ac, .cntmask
            st          ac, .dt_cnt
            ld          x6, .dt_ptr      ; BX pointer = tag word address
            ld          ac, .dt_cnt
            ngtr        ac, x7           ; -count
            movr.rz     x7, x7           ; count 0 -> skip body
            jmp         .dp_adv
dp_lp:      incldb      ac, x6, 7
            callr       .io_putc         ; preserves x6, x7
            incr.rn     x7, x7
            jmp         .dp_lp
dp_adv:     ld          x4, .dt_ptr      ; ptr += 1 + ceil(count/5)
            incr        x4, x4
            ld          ac, .dt_cnt
            addi        ac, ac, 4
            div         .fivew
            movr        mq, ac
            addr        ac, x4
            st          x4, .dt_ptr
            rets

dt_ptr:     bss         1
dt_word:    bss         1
dt_tag:     bss         1
dt_cnt:     bss         1


; ==========================================================================
; rev_print — given a token word in ac (operator or keyword), print its text.
; ==========================================================================
rev_print:  save        x4, x5
            st          ac, .rv_w
            ldea        x4, .rev_tab
rv_lp:      ld          x5, (x4)         ; tag word (0 = end)
            movr.rz     x5, x5
            jmp         .rv_none
            ld          ac, .rv_w
            sub         ac, (x4)         ; compare token word
            movr.rn     ac, ac           ; skip jmp when match
            jmp         .rv_next
            ld          x0, 1(x4)        ; dsn pointer
            callr       .io_puts
            rets
rv_next:    addi        x4, x4, 2
            jmp         .rv_lp
rv_none:    ldea        ac, 63           ; '?'
            callr       .io_putc
            rets

rv_w:       bss         1


; ==========================================================================
; tok_size — size in words of the token at x0.  Returns size in ac.
; ==========================================================================
tok_size:   save        x4
            ld          ac, (x0)
            st          ac, .tz_word
            and         ac, .tagmask
            st          ac, .tz_tag
            sub         ac, .tknint
            movr.rn     ac, ac           ; INT ?
            jmp         .tz_nI
            ldea        ac, 2
            rets
tz_nI:      ld          ac, .tz_tag
            sub         ac, .tknvar
            movr.rn     ac, ac           ; VAR ?
            jmp         .tz_nV
            jmp         .tz_pk
tz_nV:      ld          ac, .tz_tag
            sub         ac, .tknstr
            movr.rn     ac, ac           ; STR ?
            jmp         .tz_nS
            jmp         .tz_pk
tz_nS:      ldea        ac, 1            ; operator / keyword
            rets
tz_pk:      ld          ac, .tz_word     ; 1 + ceil(count/5)
            and         ac, .cntmask
            addi        ac, ac, 4
            div         .fivew
            movr        mq, ac
            addi        ac, ac, 1
            rets

tz_word:    bss         1
tz_tag:     bss         1


; ==========================================================================
; tok_blklen — count words in the tokbuf statement (including TKN_EOL).
; Result in toklen.  Walks by token structure so embedded 0 data words
; (e.g. the literal 0) are not mistaken for the end marker.
; ==========================================================================
tok_blklen: save        x4, x5
            ldea        x4, .tokbuf
            xorr        x5, x5
tb_lp:      ld          ac, (x4)
            movr.rz     ac, ac           ; word != 0 ?
            jmp         .tb_eol
            movr        x4, x0
            st          x4, .tb_save
            calls       .tok_size        ; ac = token size
            ld          x4, .tb_save
            addr        ac, x4           ; advance ptr
            addr        ac, x5           ; total += size
            jmp         .tb_lp
tb_eol:     incr        x5, x5           ; count the EOL word
            st          x5, .toklen
            rets

tb_save:    bss         1
toklen:     bss         1


; ==========================================================================
; ln_find — locate line lnum (x0).  Sets ln_ptr = first line with number
; >= lnum (the insertion point) and ln_match = 1 if an exact match exists.
; ==========================================================================
ln_find:    save        x4, x5, x6
            st          x0, .lf_num
            ldea        x4, .progbase
lf_lp:      ld          x5, .progend
            cmplt       x4, x5           ; ptr < progend ?
            jmp         .lf_chk
            jmp         .lf_end
lf_chk:     ld          x6, (x4)         ; this line number
            ld          x5, .lf_num
            cmpge       x6, x5           ; lineno >= lnum ?
            jmp         .lf_here
            ld          ac, 1(x4)        ; advance: header(2) + token count
            addi        ac, ac, 2
            addr        ac, x4
            jmp         .lf_lp
lf_here:    st          x4, .ln_ptr
            ld          ac, (x4)
            sub         ac, .lf_num
            movr.rn     ac, ac           ; exact match ?
            jmp         .lf_nomat
            ldea        ac, 1
            st          ac, .ln_match
            rets
lf_nomat:   xorr        ac, ac
            st          ac, .ln_match
            rets
lf_end:     st          x4, .ln_ptr      ; past last line (append point)
            xorr        ac, ac
            st          ac, .ln_match
            rets

lf_num:     bss         1
ln_ptr:     bss         1
ln_match:   bss         1


; ==========================================================================
; shift_up — open a gap of x1 words at address x0; progend += x1.
; ==========================================================================
shift_up:   save        x4, x5, x6, x7
            movr        x0, x6           ; lower bound
            ld          x4, .progend
            addi        x4, x4, -1       ; src = progend - 1
su_lp:      cmpge       x4, x6           ; src >= at ?
            jmp         .su_do
            jmp         .su_fin
su_do:      ld          ac, (x4)
            movr        x4, x5
            addr        x1, x5           ; dst = src + cnt
            st          ac, (x5)
            addi        x4, x4, -1
            jmp         .su_lp
su_fin:     ld          ac, .progend
            addr        x1, ac
            st          ac, .progend
            rets


; ==========================================================================
; shift_dn — remove x1 words at address x0; progend -= x1.
; ==========================================================================
shift_dn:   save        x4, x5, x6, x7
            movr        x0, x4
            addr        x1, x4           ; src = at + cnt
            ld          x6, .progend
sd_lp:      cmplt       x4, x6           ; src < progend ?
            jmp         .sd_do
            jmp         .sd_fin
sd_do:      ld          ac, (x4)
            movr        x4, x5
            ngtr        x1, x7
            addr        x7, x5           ; dst = src - cnt
            st          ac, (x5)
            incr        x4, x4
            jmp         .sd_lp
sd_fin:     ld          ac, .progend
            ngtr        x1, x7
            addr        x7, ac
            st          ac, .progend
            rets


; ==========================================================================
; ln_delete — remove line lnum (x0) if present.
; ==========================================================================
ln_delete:  save        x4
            calls       .ln_find
            ld          ac, .ln_match
            movr.rz     ac, ac           ; skip jmp when match present
            jmp         .lde_no
            ld          x4, .ln_ptr
            ld          ac, 1(x4)
            addi        ac, ac, 2        ; size = header + tokens
            st          ac, .lde_sz
            ld          x0, .ln_ptr
            ld          x1, .lde_sz
            calls       .shift_dn
lde_no:     rets

lde_sz:     bss         1


; ==========================================================================
; ln_insert — store line lnum (x0); tokbuf/toklen hold its token block.
; Replaces any existing line with the same number.
; ==========================================================================
ln_insert:  save        x4, x5, x6
            st          x0, .li_num
            calls       .ln_delete       ; remove old copy if any
            ld          x0, .li_num
            calls       .ln_find         ; insertion point -> ln_ptr
            ld          ac, .toklen
            addi        ac, ac, 2        ; new line size
            st          ac, .li_sz
            ld          x0, .ln_ptr
            ld          x1, .li_sz
            calls       .shift_up
            ld          x4, .ln_ptr
            ld          ac, .li_num
            st          ac, (x4)         ; line number
            ld          ac, .toklen
            st          ac, 1(x4)        ; token count
            addi        x4, x4, 2
            ldea        x5, .tokbuf
            ld          x6, .toklen
            ngtr        x6, x6
            movr.rz     x6, x6           ; no tokens?
            jmp         .li_done
li_cp:      ld          ac, (x5)
            st          ac, (x4)
            incr        x4, x4
            incr        x5, x5
            incr.rn     x6, x6
            jmp         .li_cp
li_done:    rets

li_num:     bss         1
li_sz:      bss         1


; ==========================================================================
; do_edit — store or delete a numbered program line from linebuf.
; ==========================================================================
do_edit:    save        x4, x5
            ; parse the leading line number
            ldea        x4, .linebuf
            xorr        x5, x5           ; value
de_num:     ld          ac, (x4)
            callr       .id_digit        ; clobbers x6,x7 (x4,x5 safe)
            movr.rz     ac, ac           ; skip jmp when digit
            jmp         .de_done
            ld          ac, (x4)
            addi        ac, ac, -48
            st          ac, .de_dig
            movr        x5, mq
            mul         .tenw
            add         ac, .de_dig
            movr        ac, x5
            incr        x4, x4
            jmp         .de_num
de_done:    st          x5, .de_lnum     ; line number
            st          x4, .de_rest     ; pointer to remaining text
            ldea        x4, .linebuf     ; remaining count = (linebuf+linelen) - rest
            ld          x5, .linelen
            addr        x5, x4           ; x4 = end of line
            ld          x5, .de_rest
            ngtr        x5, x5
            addr        x5, x4           ; x4 = end - rest
            st          x4, .de_cnt
            ld          x0, .de_rest     ; tokenize the remainder
            ld          x1, .de_cnt
            calls       .tok_line
            calls       .tok_blklen      ; -> toklen
            ; empty statement (toklen == 1, just EOL) -> delete
            ld          ac, .toklen
            subin.rn    ac, ac, 1        ; toklen == 1 ?
            jmp         .de_store
            ld          x0, .de_lnum
            calls       .ln_delete
            rets
de_store:   ld          x0, .de_lnum
            calls       .ln_insert
            rets

de_dig:     bss         1
de_lnum:    bss         1
de_rest:    bss         1
de_cnt:     bss         1


; ==========================================================================
; st_list — LIST the stored program.
; ==========================================================================
st_list:    save        x4, x5
            ldea        x4, .progbase
sl_lp:      ld          x5, .progend
            cmplt       x4, x5           ; ptr < progend ?
            jmp         .sl_line
            jmp         .sl_done
sl_line:    st          x4, .sl_save
            ld          ac, (x4)         ; line number
            callr       .io_putn
            ldea        ac, 32           ; space
            callr       .io_putc
            ld          x4, .sl_save
            movr        x4, x0
            addi        x0, x0, 2        ; token block
            calls       .detok           ; prints tokens + CRLF
            ld          x4, .sl_save
            ld          ac, 1(x4)
            addi        ac, ac, 2
            addr        ac, x4           ; next line
            jmp         .sl_lp
sl_done:    rets

sl_save:    bss         1


; ==========================================================================
; st_new — clear the program and all variables.
; ==========================================================================
st_new:     save        x4
            ldea        ac, .progbase
            st          ac, .progend
            ld          ac, .memtop
            st          ac, .varbot
            ldea        ac, .strheap     ; reset string heap
            st          ac, .strnext
            xorr        ac, ac
            st          ac, .for_sp
            st          ac, .gosub_sp
            rets


; ==========================================================================
; st_rem — REM: ignore the rest of the line.
; ==========================================================================
st_rem:     save        x4
            rets


; ==========================================================================
; par_exec — execute the tokenized statement at x0 via the dispatch table.
; ==========================================================================
par_exec:   save        x4
            st          x0, .cur_tok
            ld          x4, .cur_tok
            ld          ac, (x4)
            movr.rz     ac, ac           ; skip rets when statement present
            rets                          ; empty line: nothing to do
            st          ac, .pe_w
            ; a VAR as the first token is an implicit LET
            and         ac, .tagmask
            sub         ac, .tknvar
            movr.rn     ac, ac           ; skip jmp when VAR
            jmp         .pe_kw
            ld          ac, .cur_tok     ; ep_tok = cur_tok (at the variable)
            st          ac, .ep_tok
            calls       .st_let
            rets
pe_kw:      ldea        x4, .st_tab
pe_lp:      ld          ac, (x4)         ; tag (0 = end)
            movr.rz     ac, ac
            jmp         .pe_unk
            ld          ac, .pe_w
            sub         ac, (x4)
            movr.rn     ac, ac           ; match ?
            jmp         .pe_next
            ld          ac, .cur_tok     ; ep_tok = cur_tok + 1 (past keyword)
            addi        ac, ac, 1
            st          ac, .ep_tok
            ld          x0, 1(x4)        ; handler address
            calls       (x0)             ; mask word lives at handler[0]
            rets
pe_next:    addi        x4, x4, 2
            jmp         .pe_lp
pe_unk:     ldea        x0, .msg_synt    ; unknown / not-yet-implemented
            callr       .io_puts
            callr       .io_crlf
            rets

pe_w:       bss         1
cur_tok:    bss         1
ep_tok:     bss         1


; ==========================================================================
; Variable table.  Each entry: name word 0, name word 1, value (3 words),
; allocated downward from memtop (varbot = current bottom).
; ==========================================================================
; var_lookup — x0 = VAR token pointer.  Returns entry address in ac,
; creating a zero-valued entry if the variable does not exist yet.
var_lookup: save        x4, x5, x6, x7
            movr        x0, x4
            ld          ac, (x4)         ; tag | count
            and         ac, .cntmask
            st          ac, .vl_cnt
            ld          ac, 1(x4)        ; body word 0
            st          ac, .vl_nm0
            ld          x5, .vl_cnt
            ld          x6, .fivew
            cmpgt       x5, x6           ; count > 5 ?
            jmp         .vl_two
            xorr        ac, ac
            st          ac, .vl_nm1
            jmp         .vl_scan
vl_two:     ld          ac, 2(x4)        ; body word 1
            st          ac, .vl_nm1
vl_scan:    ld          x4, .varbot
vl_lp:      ld          x5, .memtop
            cmplt       x4, x5           ; ptr < memtop ?
            jmp         .vl_chk
            jmp         .vl_new
vl_chk:     ld          ac, (x4)
            sub         ac, .vl_nm0
            movr.rn     ac, ac           ; nm0 match ?
            jmp         .vl_next
            ld          ac, 1(x4)
            sub         ac, .vl_nm1
            movr.rn     ac, ac           ; nm1 match ?
            jmp         .vl_next
            movr        x4, ac           ; found
            rets
vl_next:    addi        x4, x4, 4
            jmp         .vl_lp
vl_new:     ld          ac, .varbot      ; allocate a new 4-word entry
            addi        ac, ac, -4
            st          ac, .varbot
            movr        ac, x4
            ld          ac, .vl_nm0
            st          ac, (x4)
            ld          ac, .vl_nm1
            st          ac, 1(x4)
            xorr        ac, ac
            st          ac, 2(x4)        ; type = integer
            st          ac, 3(x4)        ; value = 0
            movr        x4, ac
            rets

vl_cnt:     bss         1
vl_nm0:     bss         1
vl_nm1:     bss         1


; ==========================================================================
; String runtime.  A "string value" is a pointer to a word whose low 28 bits
; are the character count, followed by ceil(count/5) packed 7-bit body words
; (the same layout as a TKN_STR token, so literals need no copying).  New
; strings are bump-allocated from strheap.
; ==========================================================================

; str_alloc — x0 = character count.  Returns a zeroed dsn string in ac
; (count word written; body words zeroed so incstb can OR into them).
str_alloc:  save        x4, x5
            st          x0, .sa_cnt
            addi        x0, ac, 4        ; ac = count + 4; nbody = ceil(count/5)
            div         .fivew
            movr        mq, ac
            addi        ac, ac, 1        ; total words = 1 + nbody
            st          ac, .sa_tot
            ld          x4, .strnext
            st          x4, .sa_ptr
            ld          ac, .sa_tot      ; new top after allocation
            addr        x4, ac
            st          ac, .sa_top
            ld          x4, .strend      ; out of string space ?
            ld          x5, .sa_top
            cmple       x5, x4           ; new top <= strend ?
            jmp         .sa_ok
            ldea        x0, .msg_oom
            jmp         .err_show
sa_ok:      ld          ac, .sa_top
            st          ac, .strnext
            ld          x4, .sa_ptr      ; zero the allocation
            ld          ac, .sa_tot
            ngtr        ac, x5
sa_zl:      xorr        ac, ac
            st          ac, (x4)
            incr        x4, x4
            incr.rn     x5, x5
            jmp         .sa_zl
            ld          x4, .sa_ptr      ; write count word
            ld          ac, .sa_cnt
            st          ac, (x4)
            ld          ac, .sa_ptr
            rets

sa_cnt:     bss         1
sa_tot:     bss         1
sa_ptr:     bss         1
sa_top:     bss         1

; str_cat — x0 = string a, x1 = string b.  Returns new string a+b in ac.
str_cat:    save        x4, x5, x6, x7
            st          x0, .sc_a
            st          x1, .sc_b
            ld          ac, (x0)
            and         ac, .cntmask
            st          ac, .sc_ca
            ld          ac, (x1)
            and         ac, .cntmask
            st          ac, .sc_cb
            ld          ac, .sc_ca
            add         ac, .sc_cb
            movr        ac, x0
            calls       .str_alloc       ; ac = new string
            st          ac, .sc_new
            movr        ac, x7           ; dest BX pointer = new
            ld          x6, .sc_a        ; copy a
            ld          ac, .sc_ca
            ngtr        ac, x4
            movr.rz     x4, x4
            jmp         .sc_b1
sc_al:      incldb      ac, x6, 7
            incstb      ac, x7, 7
            incr.rn     x4, x4
            jmp         .sc_al
sc_b1:      ld          x6, .sc_b        ; copy b
            ld          ac, .sc_cb
            ngtr        ac, x4
            movr.rz     x4, x4
            jmp         .sc_dn
sc_bl:      incldb      ac, x6, 7
            incstb      ac, x7, 7
            incr.rn     x4, x4
            jmp         .sc_bl
sc_dn:      ld          ac, .sc_new
            rets

sc_a:       bss         1
sc_b:       bss         1
sc_ca:      bss         1
sc_cb:      bss         1
sc_new:     bss         1

; str_cmp — x0 = a, x1 = b.  Returns ac = -1/0/1 (lexicographic).
str_cmp:    save        x4, x5, x6, x7
            ld          ac, (x0)
            and         ac, .cntmask
            st          ac, .scm_ca
            ld          ac, (x1)
            and         ac, .cntmask
            st          ac, .scm_cb
            movr        x0, x6           ; a BX pointer
            movr        x1, x7           ; b BX pointer
            ld          x4, .scm_ca      ; min = min(ca, cb)
            ld          x5, .scm_cb
            cmple       x4, x5           ; ca <= cb ?
            jmp         .scm_mina
            ld          ac, .scm_cb
            st          ac, .scm_min
            jmp         .scm_cl
scm_mina:   ld          ac, .scm_ca
            st          ac, .scm_min
scm_cl:     ld          ac, .scm_min
            movr.rz     ac, ac           ; skip jmp when min != 0
            jmp         .scm_len
            ngtr        ac, x5           ; x5 = -min
scm_loop:   incldb      ac, x6, 7        ; a char
            st          ac, .scm_ach
            incldb      ac, x7, 7        ; b char
            st          ac, .scm_bch
            ld          ac, .scm_ach
            sub         ac, .scm_bch
            movr.rz     ac, ac           ; skip jmp when chars differ
            jmp         .scm_eqc
            and         ac, .signbit     ; differ: sign of (a - b)
            movr.rz     ac, ac           ; skip jmp when negative
            jmp         .scm_pos
            ld          ac, .neg1
            rets
scm_pos:    ldea        ac, 1
            rets
scm_eqc:    incr.rn     x5, x5           ; skip jmp when all min chars done
            jmp         .scm_loop
scm_len:    ld          ac, .scm_ca      ; equal prefix: shorter string is less
            sub         ac, .scm_cb
            movr.rz     ac, ac           ; skip jmp when lengths differ
            jmp         .scm_eq
            and         ac, .signbit
            movr.rz     ac, ac           ; skip jmp when negative
            jmp         .scm_lpos
            ld          ac, .neg1
            rets
scm_lpos:   ldea        ac, 1
            rets
scm_eq:     xorr        ac, ac
            rets

scm_ca:     bss         1
scm_cb:     bss         1
scm_min:    bss         1
scm_ach:    bss         1
scm_bch:    bss         1

; str_print — x0 = string pointer.  Prints the characters.
str_print:  save        x4
            ld          ac, (x0)
            and         ac, .cntmask
            st          ac, .spr_cnt
            movr        x0, x6           ; BX pointer
            ld          ac, .spr_cnt
            ngtr        ac, x7
            movr.rz     x7, x7           ; skip when empty
            jmp         .spr_done
spr_lp:     incldb      ac, x6, 7
            callr       .io_putc         ; preserves x6, x7
            incr.rn     x7, x7
            jmp         .spr_lp
spr_done:   rets

spr_cnt:    bss         1


; ==========================================================================
; Integer expression evaluator (recursive descent).  All routines read and
; advance ep_tok and return the integer result in ac.
; ==========================================================================

; ex_prim — primary: INT literal, variable, function call, or ( expr ).
ex_prim:    save        x4, x5
            ld          x4, .ep_tok
            ld          ac, (x4)
            st          ac, .ex_w
            and         ac, .tagmask
            st          ac, .ex_t
            sub         ac, .tknint
            movr.rn     ac, ac           ; INT ?
            jmp         .exp_nI
            ld          ac, 1(x4)        ; value
            st          ac, .ex_val
            addi        x4, x4, 2
            st          x4, .ep_tok
            xorr        ac, ac           ; type = integer
            st          ac, .vtype
            ld          ac, .ex_val
            rets
exp_nI:     ld          ac, .ex_t
            sub         ac, .tknvar
            movr.rn     ac, ac           ; VAR ?
            jmp         .exp_nVc
            ld          x0, .ep_tok
            calls       .var_lookup      ; ac = entry
            st          ac, .exp_ent
            ld          x0, .ep_tok      ; advance past the VAR token
            calls       .tok_size
            ld          x4, .ep_tok
            addr        ac, x4
            st          x4, .ep_tok
            ld          x4, .exp_ent     ; type (word 2) and value (word 3)
            ld          ac, 2(x4)
            st          ac, .vtype
            ld          ac, 3(x4)
            rets
exp_nVc:    ld          ac, .ex_t
            sub         ac, .tknstr
            movr.rn     ac, ac           ; STR literal ?
            jmp         .exp_nV
            ld          ac, .ep_tok      ; string value = pointer to the token
            st          ac, .ex_val
            ld          x0, .ep_tok      ; advance past it
            calls       .tok_size
            ld          x4, .ep_tok
            addr        ac, x4
            st          x4, .ep_tok
            ldea        ac, 1            ; type = string
            st          ac, .vtype
            ld          ac, .ex_val
            rets
exp_nV:     ld          ac, .ex_w
            sub         ac, .v_lpar
            movr.rn     ac, ac           ; '(' ?
            jmp         .exp_nL
            ld          x4, .ep_tok      ; consume '('
            addi        x4, x4, 1
            st          x4, .ep_tok
            calls       .ex_expr         ; sets vtype
            st          ac, .ex_val
            ld          x4, .ep_tok      ; expect ')'
            ld          ac, (x4)
            sub         ac, .v_rpar
            movr.rn     ac, ac
            jmp         .exp_err
            addi        x4, x4, 1
            st          x4, .ep_tok
            ld          ac, .ex_val
            rets
exp_nL:     ld          ac, .ex_w        ; function call: <fn> ( expr )
            callr       .is_func         ; ac = function code (1..N) or 0
            movr.rz     ac, ac           ; skip jmp when it is a function
            jmp         .exp_err
            movr        ac, x5           ; x5 = function code (survives arg eval)
            ld          x4, .ep_tok      ; consume function name
            addi        x4, x4, 1
            st          x4, .ep_tok
            ld          ac, (x4)         ; expect '('
            sub         ac, .v_lpar
            movr.rn     ac, ac
            jmp         .exp_err
            addi        x4, x4, 1
            st          x4, .ep_tok
            calls       .ex_expr         ; argument in ac; x5 preserved
            st          ac, .ex_arg
            ld          ac, .vtype       ; remember argument type
            st          ac, .ex_argt
            ld          x4, .ep_tok      ; expect ')'
            ld          ac, (x4)
            sub         ac, .v_rpar
            movr.rn     ac, ac
            jmp         .exp_err
            addi        x4, x4, 1
            st          x4, .ep_tok
            st          x5, .ex_fn       ; store fn code + arg, then apply
            calls       .apply_fn        ; ac = result; apply_fn sets vtype
            rets
exp_err:    ldea        x0, .msg_synt
            jmp         .err_show

ex_w:       bss         1
ex_t:       bss         1
ex_val:     bss         1
ex_fn:      bss         1
ex_arg:     bss         1
ex_argt:    bss         1
exp_ent:    bss         1
vtype:      bss         1

; is_func — token word in ac -> 1=PEEK 2=ABS 3=SGN 4=RND 5=INT, else 0.
is_func:    st          ac, .if_w
            sub         ac, .v_peek
            movr.rn     ac, ac
            jmp         .iff_2
            ldea        ac, 1
            retr
iff_2:      ld          ac, .if_w
            sub         ac, .v_abs
            movr.rn     ac, ac
            jmp         .iff_3
            ldea        ac, 2
            retr
iff_3:      ld          ac, .if_w
            sub         ac, .v_sgn
            movr.rn     ac, ac
            jmp         .iff_4
            ldea        ac, 3
            retr
iff_4:      ld          ac, .if_w
            sub         ac, .v_rnd
            movr.rn     ac, ac
            jmp         .iff_5
            ldea        ac, 4
            retr
iff_5:      ld          ac, .if_w
            sub         ac, .v_int
            movr.rn     ac, ac
            jmp         .iff_0
            ldea        ac, 5
            retr
iff_0:      xorr        ac, ac
            retr

if_w:       bss         1

; apply_fn — apply function ex_fn to ex_arg; result in ac.
apply_fn:   save        x4
            xorr        ac, ac           ; functions here all return integers
            st          ac, .vtype
            ld          ac, .ex_fn
            subin.rn    ac, ac, 1
            jmp         .af_2
            ld          x4, .ex_arg      ; PEEK
            ld          ac, (x4)
            rets
af_2:       ld          ac, .ex_fn
            subin.rn    ac, ac, 2
            jmp         .af_3
            ld          ac, .ex_arg      ; ABS
            and         ac, .signbit
            movr.rz     ac, ac           ; skip jmp when negative
            jmp         .af_apos
            ld          ac, .ex_arg
            ngtr        ac, ac
            rets
af_apos:    ld          ac, .ex_arg
            rets
af_3:       ld          ac, .ex_fn
            subin.rn    ac, ac, 3
            jmp         .af_4
            ld          ac, .ex_arg      ; SGN
            movr.rz     ac, ac           ; skip jmp when nonzero
            jmp         .af_szero
            ld          ac, .ex_arg
            and         ac, .signbit
            movr.rz     ac, ac           ; skip jmp when negative
            jmp         .af_spos
            ld          ac, .neg1
            rets
af_spos:    ldea        ac, 1
            rets
af_szero:   xorr        ac, ac
            rets
af_4:       ld          ac, .ex_fn
            subin.rn    ac, ac, 4
            jmp         .af_int
            ld          ac, .rnd_seed    ; RND: LCG, result in [0, arg)
            movr        ac, mq
            mul         .rnd_mul
            add         ac, .rnd_inc
            st          ac, .rnd_seed
            ld          x4, .ex_arg
            movr.rz     x4, x4           ; skip jmp when arg != 0
            jmp         .af_rzero
            jmp         .af_rmod
af_rzero:   xorr        ac, ac
            rets
af_rmod:    ld          ac, .rnd_seed
            and         ac, .lo35        ; force non-negative
            div         .ex_arg          ; xy = seed mod arg
            movr        xy, ac
            rets
af_int:     ld          ac, .ex_arg      ; INT (identity for integers)
            rets

; ex_fact — unary minus, then primary.
ex_fact:    save        x4
            ld          x4, .ep_tok
            ld          ac, (x4)
            sub         ac, .v_minus
            movr.rn     ac, ac           ; unary '-' ?
            jmp         .ef_prim
            addi        x4, x4, 1
            st          x4, .ep_tok
            calls       .ex_fact
            ngtr        ac, ac
            rets
ef_prim:    calls       .ex_prim
            rets

; ex_term — factor ( ('*'|'/') factor )*.  Accumulator in saved x5.
ex_term:    save        x4, x5
            calls       .ex_fact
            movr        ac, x5           ; x5 = accumulator
et_lp:      ld          x4, .ep_tok
            ld          ac, (x4)
            sub         ac, .v_mul
            movr.rn     ac, ac           ; '*' ?
            jmp         .et_cdiv
            ld          x4, .ep_tok
            addi        x4, x4, 1
            st          x4, .ep_tok
            calls       .ex_fact         ; operand in ac; x5 preserved
            st          ac, .et_t
            movr        x5, mq
            mul         .et_t            ; ac = acc * operand
            movr        ac, x5
            jmp         .et_lp
et_cdiv:    ld          x4, .ep_tok
            ld          ac, (x4)
            sub         ac, .v_div
            movr.rn     ac, ac           ; '/' ?
            jmp         .et_done
            ld          x4, .ep_tok
            addi        x4, x4, 1
            st          x4, .ep_tok
            calls       .ex_fact
            st          ac, .et_t
            movr        x5, ac
            div         .et_t            ; mq = acc / operand
            movr        mq, x5
            jmp         .et_lp
et_done:    movr        x5, ac
            rets

et_t:       bss         1

; ex_add — term ( ('+'|'-') term )*.  Accumulator value in saved x5, its
; type in saved x6.  '+' adds integers or concatenates strings; '-' is
; integer-only.
ex_add:     save        x4, x5, x6
            calls       .ex_term
            movr        ac, x5           ; x5 = accumulator value
            ld          ac, .vtype
            movr        ac, x6           ; x6 = accumulator type
ea_lp:      ld          x4, .ep_tok
            ld          ac, (x4)
            sub         ac, .v_plus
            movr.rn     ac, ac           ; '+' ?
            jmp         .ea_cmin
            ld          x4, .ep_tok
            addi        x4, x4, 1
            st          x4, .ep_tok
            calls       .ex_term         ; operand value in ac, type in vtype
            st          ac, .ea_opv
            ld          ac, .vtype
            st          ac, .ea_opt
            movr        x6, ac           ; accumulator type
            movr.rz     ac, ac
            jmp         .ea_iadd         ; accumulator integer -> integer add
            jmp         .ea_strp         ; accumulator string  -> concatenate
ea_strp:    ld          ac, .ea_opt
            movr.rz     ac, ac
            jmp         .ea_tmm          ; operand integer -> mismatch
            movr        x5, x0           ; concat(acc, operand)
            ld          x1, .ea_opv
            calls       .str_cat
            movr        ac, x5
            jmp         .ea_lp
ea_iadd:    ld          ac, .ea_opt
            movr.rz     ac, ac
            jmp         .ea_addok        ; operand integer -> add
            jmp         .ea_tmm          ; operand string  -> mismatch
ea_addok:   ld          ac, .ea_opv
            addr        ac, x5
            jmp         .ea_lp
ea_cmin:    ld          x4, .ep_tok
            ld          ac, (x4)
            sub         ac, .v_minus
            movr.rn     ac, ac           ; '-' ?
            jmp         .ea_done
            ld          x4, .ep_tok
            addi        x4, x4, 1
            st          x4, .ep_tok
            movr        x6, ac           ; '-' requires integer accumulator
            movr.rz     ac, ac
            jmp         .ea_subai
            jmp         .ea_tmm
ea_subai:   calls       .ex_term
            st          ac, .ea_opv
            ld          ac, .vtype       ; and integer operand
            movr.rz     ac, ac
            jmp         .ea_suboi
            jmp         .ea_tmm
ea_suboi:   ld          ac, .ea_opv
            subr        ac, x5           ; x5 -= operand
            jmp         .ea_lp
ea_done:    movr        x6, ac           ; vtype = accumulator type
            st          ac, .vtype
            movr        x5, ac           ; ac = accumulator value
            rets
ea_tmm:     ldea        x0, .msg_tmm
            jmp         .err_show

ea_opv:     bss         1
ea_opt:     bss         1

; ex_expr — relational: add ( relop add )?  True = -1, false = 0.
; left in saved x4, relop code in saved x6 across the right-hand evaluation.
ex_expr:    save        x4, x5, x6
            calls       .ex_add
            movr        ac, x4           ; x4 = left value
            ld          ac, .vtype       ; left type (global survives right eval)
            st          ac, .ex_lt
            ld          x5, .ep_tok
            ld          ac, (x5)
            callr       .is_relop        ; ac = code (1..6) or 0
            movr.rz     ac, ac           ; skip jmp when relop present
            jmp         .exx_done
            movr        ac, x6           ; x6 = relop code
            ld          x5, .ep_tok      ; consume relop
            addi        x5, x5, 1
            st          x5, .ep_tok
            calls       .ex_add          ; right in ac; x4, x6 preserved
            st          x4, .ex_l
            st          ac, .ex_r
            st          x6, .ex_relop
            ld          ac, .ex_lt       ; operand types must match
            sub         ac, .vtype
            movr.rn     ac, ac
            jmp         .exx_tmm
            ld          ac, .ex_lt       ; string operands -> compare lexically
            movr.rz     ac, ac
            jmp         .exx_num
            ld          x0, .ex_l
            ld          x1, .ex_r
            calls       .str_cmp         ; ac = -1/0/1
            st          ac, .ex_l        ; reduce to (cmp relop 0)
            xorr        ac, ac
            st          ac, .ex_r
exx_num:    calls       .rel_eval        ; ac = -1 / 0
            xorr        x4, x4           ; result type = integer
            st          x4, .vtype
            rets
exx_done:   movr        x4, ac
            rets
exx_tmm:    ldea        x0, .msg_tmm
            jmp         .err_show

ex_l:       bss         1
ex_r:       bss         1
ex_lt:      bss         1
ex_relop:   bss         1

; is_relop — token word in ac -> relop code (1=EQ 2=LT 3=GT 4=LE 5=GE 6=NE) or 0.
is_relop:   st          ac, .ir_w
            sub         ac, .v_eq
            movr.rn     ac, ac
            jmp         .ir_1
            ldea        ac, 1
            retr
ir_1:       ld          ac, .ir_w
            sub         ac, .tknlt
            movr.rn     ac, ac
            jmp         .ir_2
            ldea        ac, 2
            retr
ir_2:       ld          ac, .ir_w
            sub         ac, .tkngt
            movr.rn     ac, ac
            jmp         .ir_3
            ldea        ac, 3
            retr
ir_3:       ld          ac, .ir_w
            sub         ac, .tknle
            movr.rn     ac, ac
            jmp         .ir_4
            ldea        ac, 4
            retr
ir_4:       ld          ac, .ir_w
            sub         ac, .tknge
            movr.rn     ac, ac
            jmp         .ir_5
            ldea        ac, 5
            retr
ir_5:       ld          ac, .ir_w
            sub         ac, .tknne
            movr.rn     ac, ac
            jmp         .ir_0
            ldea        ac, 6
            retr
ir_0:       xorr        ac, ac
            retr

ir_w:       bss         1

; rel_eval — compare ex_l, ex_r per ex_relop; ac = -1 (true) or 0.
rel_eval:   save        x4, x5
            ld          ac, .ex_relop
            subin.rn    ac, ac, 1
            jmp         .rv_1
            jmp         .re_eq
rv_1:       ld          ac, .ex_relop
            subin.rn    ac, ac, 2
            jmp         .rv_2
            jmp         .re_lt
rv_2:       ld          ac, .ex_relop
            subin.rn    ac, ac, 3
            jmp         .rv_3
            jmp         .re_gt
rv_3:       ld          ac, .ex_relop
            subin.rn    ac, ac, 4
            jmp         .rv_4
            jmp         .re_le
rv_4:       ld          ac, .ex_relop
            subin.rn    ac, ac, 5
            jmp         .re_ne
            jmp         .re_ge
re_eq:      ld          ac, .ex_l
            sub         ac, .ex_r
            movr.rz     ac, ac           ; skip jmp when not equal
            jmp         .re_true
            jmp         .re_false
re_ne:      ld          ac, .ex_l
            sub         ac, .ex_r
            movr.rz     ac, ac
            jmp         .re_false
            jmp         .re_true
; Signed comparisons via d = ex_l - ex_r and the sign bit (bit 35).
re_lt:      ld          ac, .ex_l
            sub         ac, .ex_r
            and         ac, .signbit
            movr.rz     ac, ac           ; skip jmp when negative
            jmp         .re_false
            jmp         .re_true
re_ge:      ld          ac, .ex_l
            sub         ac, .ex_r
            and         ac, .signbit
            movr.rz     ac, ac           ; skip jmp when negative
            jmp         .re_true
            jmp         .re_false
re_gt:      ld          ac, .ex_l
            sub         ac, .ex_r
            st          ac, .rel_d
            and         ac, .signbit
            movr.rz     ac, ac           ; skip jmp when negative
            jmp         .rgt_nn
            jmp         .re_false
rgt_nn:     ld          ac, .rel_d
            movr.rz     ac, ac           ; skip jmp when d != 0
            jmp         .re_false
            jmp         .re_true
re_le:      ld          ac, .ex_l
            sub         ac, .ex_r
            st          ac, .rel_d
            and         ac, .signbit
            movr.rz     ac, ac           ; skip jmp when negative
            jmp         .rle_nn
            jmp         .re_true
rle_nn:     ld          ac, .rel_d
            movr.rz     ac, ac           ; skip jmp when d != 0
            jmp         .re_true
            jmp         .re_false
re_true:    ld          ac, .neg1
            rets
re_false:   xorr        ac, ac
            rets

rel_d:      bss         1


; ==========================================================================
; print_str_tok — print the body of the STR token at x0; advance ep_tok.
; ==========================================================================
print_str_tok: save     x4
            ld          ac, (x0)
            and         ac, .cntmask
            st          ac, .ps_cnt
            movr        x0, x6           ; BX pointer = tag word addr
            ld          ac, .ps_cnt
            ngtr        ac, x7
            movr.rz     x7, x7
            jmp         .ps_adv
ps_lp:      incldb      ac, x6, 7
            callr       .io_putc
            incr.rn     x7, x7
            jmp         .ps_lp
ps_adv:     ld          x0, .ep_tok
            calls       .tok_size
            ld          x4, .ep_tok
            addr        ac, x4
            st          x4, .ep_tok
            rets

ps_cnt:     bss         1


; ==========================================================================
; st_print — PRINT items separated by ';' (no gap) or ',' (tab).  A trailing
; separator suppresses the newline.
; ==========================================================================
st_print:   save        x4
            xorr        ac, ac
            st          ac, .sp_supp
sp_lp:      ld          x4, .ep_tok
            ld          ac, (x4)
            movr.rz     ac, ac           ; skip jmp when a token is present
            jmp         .sp_eol
            jmp         .sp_item
sp_eol:     ld          ac, .sp_supp
            movr.rz     ac, ac           ; skip jmp when suppressing
            jmp         .sp_nl
            rets
sp_nl:      callr       .io_crlf
            rets
sp_item:    ld          x4, .ep_tok
            ld          ac, (x4)
            sub         ac, .v_semi
            movr.rn     ac, ac           ; ';' ?
            jmp         .sp_ncom
            ldea        ac, 1
            st          ac, .sp_supp
            ld          x4, .ep_tok
            addi        x4, x4, 1
            st          x4, .ep_tok
            jmp         .sp_lp
sp_ncom:    ld          x4, .ep_tok
            ld          ac, (x4)
            sub         ac, .v_comma
            movr.rn     ac, ac           ; ',' ?
            jmp         .sp_expr
            ldea        ac, 1
            st          ac, .sp_supp
            ldea        ac, 9            ; tab
            callr       .io_putc
            ld          x4, .ep_tok
            addi        x4, x4, 1
            st          x4, .ep_tok
            jmp         .sp_lp
sp_expr:    xorr        ac, ac
            st          ac, .sp_supp
            calls       .ex_expr         ; value in ac, type in vtype
            st          ac, .sp_val
            ld          ac, .vtype
            movr.rz     ac, ac           ; skip jmp when string
            jmp         .sp_pint
            ld          x0, .sp_val      ; string: print its characters
            calls       .str_print
            jmp         .sp_lp
sp_pint:    ld          ac, .sp_val
            callr       .io_putn
            jmp         .sp_lp

sp_supp:    bss         1
sp_val:     bss         1


; ==========================================================================
; st_let — assign:  [LET] var = expr  (ep_tok at the variable).
; ==========================================================================
st_let:     save        x4
            ld          x4, .ep_tok
            ld          ac, (x4)
            and         ac, .tagmask
            sub         ac, .tknvar
            movr.rn     ac, ac           ; VAR ?
            jmp         .sl_err
            ld          x0, .ep_tok
            calls       .var_lookup
            st          ac, .sl_ent
            ld          x0, .ep_tok      ; advance past variable
            calls       .tok_size
            ld          x4, .ep_tok
            addr        ac, x4
            st          x4, .ep_tok
            ld          ac, (x4)         ; expect '='
            sub         ac, .v_eq
            movr.rn     ac, ac
            jmp         .sl_err
            addi        x4, x4, 1
            st          x4, .ep_tok
            calls       .ex_expr
            ld          x4, .sl_ent
            st          ac, 3(x4)        ; value
            ld          ac, .vtype       ; type
            st          ac, 2(x4)
            rets
sl_err:     ldea        x0, .msg_synt
            jmp         .err_show

sl_ent:     bss         1


; ==========================================================================
; err_show — print error message (x0), reset to the READY loop.
; ==========================================================================
err_show:   ldea        sp, .topstk
            callr       .io_puts
            callr       .io_crlf
            xorr        ac, ac
            st          ac, .runflag
            jmp         .ready


; ==========================================================================
; run_exec — run the program from cur_line until END/STOP or past the end.
; ==========================================================================
run_exec:   save        x4, x5
            ldea        ac, 1
            st          ac, .runflag
re_lp:      ld          ac, .runflag
            movr.rz     ac, ac           ; skip jmp when running
            jmp         .re_done
            ld          x4, .cur_line
            ld          x5, .progend
            cmplt       x4, x5           ; cur_line < progend ?
            jmp         .re_x
            jmp         .re_done
re_x:       xorr        ac, ac
            st          ac, .jumped
            ld          x4, .cur_line
            addi        x4, x4, 2
            movr        x4, x0
            calls       .par_exec
            ld          ac, .jumped
            movr.rz     ac, ac           ; skip jmp when jumped
            jmp         .re_adv
            jmp         .re_lp
re_adv:     ld          x4, .cur_line
            ld          ac, 1(x4)
            addi        ac, ac, 2
            addr        ac, x4
            st          x4, .cur_line
            jmp         .re_lp
re_done:    xorr        ac, ac
            st          ac, .runflag
            rets


; ==========================================================================
; st_run — RUN: execute the program from the first line.
; ==========================================================================
st_run:     save        x4
            ldea        ac, .progbase
            st          ac, .cur_line
            xorr        ac, ac
            st          ac, .gosub_sp
            calls       .run_exec
            rets


; ==========================================================================
; st_goto — GOTO <line>.  During RUN sets cur_line + jumped; in direct mode
; starts execution at the target.
; ==========================================================================
st_goto:    save        x4
            calls       .ex_expr
            st          ac, .goto_ln
            ld          x0, .goto_ln
            calls       .ln_find
            ld          ac, .ln_match
            movr.rz     ac, ac           ; skip jmp when found
            jmp         .sg_err
            ld          ac, .ln_ptr
            st          ac, .cur_line
            ld          ac, .runflag
            movr.rz     ac, ac           ; skip jmp when running
            jmp         .sg_direct
            ldea        ac, 1
            st          ac, .jumped
            rets
sg_direct:  calls       .run_exec
            rets
sg_err:     ldea        x0, .msg_undef
            jmp         .err_show

goto_ln:    bss         1


; ==========================================================================
; st_if — IF <expr> THEN <line | statement>.
; ==========================================================================
st_if:      save        x4
            calls       .ex_expr
            movr.rz     ac, ac           ; skip jmp when condition true
            jmp         .if_false
            ld          x4, .ep_tok      ; expect THEN
            ld          ac, (x4)
            sub         ac, .v_then
            movr.rn     ac, ac
            jmp         .if_err
            addi        x4, x4, 1
            st          x4, .ep_tok      ; consume THEN
            ld          ac, (x4)         ; line number after THEN -> GOTO
            and         ac, .tagmask
            sub         ac, .tknint
            movr.rn     ac, ac
            jmp         .if_stmt
            calls       .st_goto
            rets
if_stmt:    ld          x0, .ep_tok      ; statement after THEN
            calls       .par_exec
            rets
if_false:   rets                          ; skip remainder of the line
if_err:     ldea        x0, .msg_synt
            jmp         .err_show


; ==========================================================================
; st_end / st_stop — stop program execution.
; ==========================================================================
st_end:     save        x4
            xorr        ac, ac
            st          ac, .runflag
            rets

st_stop:    save        x4
            xorr        ac, ac
            st          ac, .runflag
            rets


; ==========================================================================
; st_gosub — GOSUB <line>: push the next line, then jump.
; ==========================================================================
st_gosub:   save        x4, x5, x6
            calls       .ex_expr
            st          ac, .goto_ln
            ld          x0, .goto_ln
            calls       .ln_find
            ld          ac, .ln_match
            movr.rz     ac, ac           ; skip jmp when found
            jmp         .gs_err
            ld          x4, .cur_line    ; push address of the next line
            ld          ac, 1(x4)
            addi        ac, ac, 2
            addr        ac, x4
            ld          x5, .gosub_sp
            ldea        x6, .gosub_st
            addr        x5, x6
            st          x4, (x6)
            incr        x5, x5
            st          x5, .gosub_sp
            ld          ac, .ln_ptr
            st          ac, .cur_line
            ld          ac, .runflag
            movr.rz     ac, ac           ; skip jmp when running
            jmp         .gs_direct
            ldea        ac, 1
            st          ac, .jumped
            rets
gs_direct:  calls       .run_exec
            rets
gs_err:     ldea        x0, .msg_undef
            jmp         .err_show


; ==========================================================================
; st_return — RETURN: pop the saved line and resume there.
; ==========================================================================
st_return:  save        x4, x5
            ld          x4, .gosub_sp
            movr.rz     x4, x4           ; skip jmp when stack non-empty
            jmp         .rt_err
            addi        x4, x4, -1
            st          x4, .gosub_sp
            ldea        x5, .gosub_st
            addr        x4, x5
            ld          ac, (x5)
            st          ac, .cur_line
            ldea        ac, 1
            st          ac, .jumped
            rets
rt_err:     ldea        x0, .msg_rgos
            jmp         .err_show


; ==========================================================================
; st_poke — POKE <addr>, <value>.
; ==========================================================================
st_poke:    save        x4
            calls       .ex_expr
            st          ac, .poke_a
            ld          x4, .ep_tok      ; expect comma
            ld          ac, (x4)
            sub         ac, .v_comma
            movr.rn     ac, ac
            jmp         .pk_err
            addi        x4, x4, 1
            st          x4, .ep_tok
            calls       .ex_expr
            ld          x4, .poke_a
            st          ac, (x4)
            rets
pk_err:     ldea        x0, .msg_synt
            jmp         .err_show

poke_a:     bss         1


; ==========================================================================
; st_for — FOR var = start TO limit [STEP step]
; ==========================================================================
st_for:     save        x4, x5
            ld          x4, .ep_tok      ; loop variable
            ld          ac, (x4)
            and         ac, .tagmask
            sub         ac, .tknvar
            movr.rn     ac, ac
            jmp         .sf_err
            ld          x0, .ep_tok
            calls       .var_lookup
            movr        ac, x4           ; entry; mark loop variable integer
            xorr        ac, ac
            st          ac, 2(x4)
            movr        x4, ac
            addi        ac, ac, 3        ; value address (word 3)
            st          ac, .sf_va
            ld          x0, .ep_tok      ; advance past variable
            calls       .tok_size
            ld          x4, .ep_tok
            addr        ac, x4
            st          x4, .ep_tok
            ld          ac, (x4)         ; expect '='
            sub         ac, .v_eq
            movr.rn     ac, ac
            jmp         .sf_err
            addi        x4, x4, 1
            st          x4, .ep_tok
            calls       .ex_expr         ; start
            ld          x4, .sf_va
            st          ac, (x4)
            ld          x4, .ep_tok      ; expect TO
            ld          ac, (x4)
            sub         ac, .v_to
            movr.rn     ac, ac
            jmp         .sf_err
            addi        x4, x4, 1
            st          x4, .ep_tok
            calls       .ex_expr         ; limit
            st          ac, .sf_lim
            ld          x4, .ep_tok      ; optional STEP
            ld          ac, (x4)
            sub         ac, .v_step
            movr.rn     ac, ac
            jmp         .sf_nos
            addi        x4, x4, 1
            st          x4, .ep_tok
            calls       .ex_expr
            st          ac, .sf_step
            jmp         .sf_push
sf_nos:     ldea        ac, 1
            st          ac, .sf_step
sf_push:    ld          x4, .cur_line    ; resume = line after the FOR line
            ld          ac, 1(x4)
            addi        ac, ac, 2
            addr        ac, x4
            st          x4, .sf_res
            ld          ac, .for_sp      ; frame = for_st + sp*4
            addr        ac, ac
            addr        ac, ac
            ldea        x5, .for_st
            addr        ac, x5
            ld          ac, .sf_va
            st          ac, (x5)
            ld          ac, .sf_lim
            st          ac, 1(x5)
            ld          ac, .sf_step
            st          ac, 2(x5)
            ld          ac, .sf_res
            st          ac, 3(x5)
            ld          ac, .for_sp
            incr        ac, ac
            st          ac, .for_sp
            rets
sf_err:     ldea        x0, .msg_synt
            jmp         .err_show

sf_va:      bss         1
sf_lim:     bss         1
sf_step:    bss         1
sf_res:     bss         1


; ==========================================================================
; st_next — NEXT [var]: step the loop variable; loop or fall through.
; ==========================================================================
st_next:    save        x4, x5
            ld          ac, .for_sp
            movr.rz     ac, ac           ; skip jmp when stack non-empty
            jmp         .sn_err
            ld          ac, .for_sp      ; top frame
            addi        ac, ac, -1
            addr        ac, ac
            addr        ac, ac
            ldea        x5, .for_st
            addr        ac, x5
            ld          x4, (x5)         ; value address
            ld          ac, (x4)
            add         ac, 2(x5)        ; var += step
            st          ac, (x4)
            ld          ac, 2(x5)        ; step sign
            and         ac, .signbit
            movr.rz     ac, ac           ; skip jmp when step negative
            jmp         .sn_pos
            ld          x4, (x5)         ; negative step: continue if var >= limit
            ld          ac, (x4)
            sub         ac, 1(x5)        ; var - limit
            and         ac, .signbit
            movr.rz     ac, ac           ; skip jmp when var < limit
            jmp         .sn_cont
            jmp         .sn_end
sn_pos:     ld          x4, (x5)         ; positive step: continue if var <= limit
            ld          ac, (x4)
            sub         ac, 1(x5)        ; var - limit
            st          ac, .sn_d
            movr.rz     ac, ac           ; skip jmp when nonzero
            jmp         .sn_cont
            ld          ac, .sn_d
            and         ac, .signbit
            movr.rz     ac, ac           ; skip jmp when negative
            jmp         .sn_end
            jmp         .sn_cont
sn_cont:    ld          ac, 3(x5)        ; loop back to body
            st          ac, .cur_line
            ldea        ac, 1
            st          ac, .jumped
            rets
sn_end:     ld          ac, .for_sp      ; pop frame, continue after NEXT
            addi        ac, ac, -1
            st          ac, .for_sp
            rets
sn_err:     ldea        x0, .msg_nfor
            jmp         .err_show

sn_d:       bss         1


; ==========================================================================
; parse_int — parse a signed integer from linebuf.  Returns value in ac.
; ==========================================================================
parse_int:  save        x4, x5
            ldea        x4, .linebuf
            xorr        x5, x5
            xorr        ac, ac
            st          ac, .pi_neg
pi_sp:      ld          ac, (x4)         ; skip leading spaces
            subin.rn    ac, ac, 32
            jmp         .pi_chk
            incr        x4, x4
            jmp         .pi_sp
pi_chk:     ld          ac, (x4)         ; optional '-'
            subin.rn    ac, ac, 45
            jmp         .pi_dl
            incr        x4, x4
            ldea        ac, 1
            st          ac, .pi_neg
pi_dl:      ld          ac, (x4)
            callr       .id_digit
            movr.rz     ac, ac           ; skip jmp when digit
            jmp         .pi_done
            ld          ac, (x4)
            addi        ac, ac, -48
            st          ac, .pi_d
            movr        x5, mq
            mul         .tenw
            add         ac, .pi_d
            movr        ac, x5
            incr        x4, x4
            jmp         .pi_dl
pi_done:    ld          ac, .pi_neg
            movr.rz     ac, ac           ; skip jmp when negative
            jmp         .pi_ret
            ngtr        x5, x5
pi_ret:     movr        x5, ac
            rets

pi_neg:     bss         1
pi_d:       bss         1


; ==========================================================================
; st_input — INPUT var : prompt "? ", read a line, assign an integer.
; ==========================================================================
st_input:   save        x4
            ldea        x0, .msg_inq
            callr       .io_puts
            ldea        x0, .linebuf
            ld          x1, .linemax
            callr       .io_gets
            st          ac, .linelen
            calls       .parse_int
            st          ac, .inp_val
            ld          x4, .ep_tok      ; variable
            ld          ac, (x4)
            and         ac, .tagmask
            sub         ac, .tknvar
            movr.rn     ac, ac
            jmp         .si_err
            ld          x0, .ep_tok
            calls       .var_lookup
            movr        ac, x4
            xorr        ac, ac           ; type = integer
            st          ac, 2(x4)
            ld          ac, .inp_val
            st          ac, 3(x4)
            rets
si_err:     ldea        x0, .msg_synt
            jmp         .err_show

inp_val:    bss         1


; ==========================================================================
; Read-only data
; ==========================================================================

fgcw:       dw          0740000000000    ; psw1: IRQL = 15
irqmask:    dw          02000            ; enable level 10
nomask:     dw          0
ttyconf:    dw          #1F9A0           ; ENABLED|INTR_RET|INTR_OUT|DESTRUCT|echo

crlfbuf:    dw          13, 10

msg_ban:    dsn         "VIBASIC V0.1"
msg_free:   dsn         " WORDS FREE"
msg_rdy:    dsn         "READY."
msg_synt:   dsn         "?SYNTAX ERROR"
msg_undef:  dsn         "?UNDEF'D LINE"
msg_rgos:   dsn         "?RETURN WITHOUT GOSUB"
msg_nfor:   dsn         "?NEXT WITHOUT FOR"
msg_inq:    dsn         "? "
msg_tmm:    dsn         "?TYPE MISMATCH"
msg_oom:    dsn         "?OUT OF MEMORY"

; Statement dispatch table: [keyword tag value, handler], terminated by 0.
; New statements are added here plus one handler — no change to par_exec.
st_tab:     dw          #280000000, st_list      ; LIST
            dw          #290000000, st_new       ; NEW
            dw          #200000000, st_rem       ; REM
            dw          #210000000, st_print     ; PRINT
            dw          #220000000, st_let       ; LET
            dw          #230000000, st_goto      ; GOTO
            dw          #240000000, st_if        ; IF
            dw          #260000000, st_end       ; END
            dw          #270000000, st_run       ; RUN
            dw          #2A0000000, st_gosub     ; GOSUB
            dw          #2B0000000, st_return    ; RETURN
            dw          #2C0000000, st_stop      ; STOP
            dw          #2D0000000, st_poke      ; POKE
            dw          #2E0000000, st_for       ; FOR
            dw          #2F0000000, st_next      ; NEXT
            dw          #320000000, st_input     ; INPUT
            dw          0, 0


; ==========================================================================
; Token tag constants (tag value in bits 35:28).  Only those referenced by
; code are kept as named words; the rest appear as literals in the tables.
; ==========================================================================
tagmask:    dw          #FF0000000       ; bits 35:28
cntmask:    dw          #FFFFFFF         ; bits 27:0 (packed-token char count)
signbit:    dw          #800000000       ; bit 35 (sign)

tknint:     dw          #10000000        ; tag 0x01
tknvar:     dw          #20000000        ; tag 0x02
tknstr:     dw          #30000000        ; tag 0x03
tknlt:      dw          #1A0000000       ; tag 0x1A  '<'
tkngt:      dw          #1B0000000       ; tag 0x1B  '>'
tknle:      dw          #1C0000000       ; tag 0x1C  '<='
tknge:      dw          #1D0000000       ; tag 0x1D  '>='
tknne:      dw          #1E0000000       ; tag 0x1E  '<>'

; Operator / keyword token values used by the evaluator and statements
v_plus:     dw          #100000000
v_minus:    dw          #110000000
v_mul:      dw          #120000000
v_div:      dw          #130000000
v_lpar:     dw          #140000000
v_rpar:     dw          #150000000
v_comma:    dw          #160000000
v_semi:     dw          #170000000
v_eq:       dw          #190000000
v_then:     dw          #250000000
v_to:       dw          #300000000       ; TO, tag 0x30
v_step:     dw          #310000000       ; STEP, tag 0x31
v_peek:     dw          #400000000       ; PEEK function, tag 0x40
v_abs:      dw          #410000000       ; ABS, tag 0x41
v_sgn:      dw          #420000000       ; SGN, tag 0x42
v_rnd:      dw          #430000000       ; RND, tag 0x43
v_int:      dw          #440000000       ; INT, tag 0x44
neg1:       dw          -1
lo35:       dw          #7FFFFFFFF       ; low 35 bits (clears sign)
rnd_mul:    dw          1103515245
rnd_inc:    dw          12345
rnd_seed:   dw          1

; Keyword name strings (for forward lookup and detok)
s_rem:      dsn         "REM"
s_print:    dsn         "PRINT"
s_let:      dsn         "LET"
s_goto:     dsn         "GOTO"
s_if:       dsn         "IF"
s_then:     dsn         "THEN"
s_end:      dsn         "END"
s_run:      dsn         "RUN"
s_list:     dsn         "LIST"
s_new:      dsn         "NEW"
s_gosub:    dsn         "GOSUB"
s_return:   dsn         "RETURN"
s_stop:     dsn         "STOP"
s_poke:     dsn         "POKE"
s_peek:     dsn         "PEEK"
s_for:      dsn         "FOR"
s_next:     dsn         "NEXT"
s_to:       dsn         "TO"
s_step:     dsn         "STEP"
s_input:    dsn         "INPUT"
s_abs:      dsn         "ABS"
s_sgn:      dsn         "SGN"
s_rnd:      dsn         "RND"
s_int:      dsn         "INT"

; Operator symbol strings (for detok)
o_plus:     dsn         "+"
o_minus:    dsn         "-"
o_mul:      dsn         "*"
o_div:      dsn         "/"
o_lpar:     dsn         "("
o_rpar:     dsn         ")"
o_comma:    dsn         ","
o_semi:     dsn         ";"
o_colon:    dsn         ":"
o_eq:       dsn         "="
o_lt:       dsn         "<"
o_gt:       dsn         ">"
o_le:       dsn         "<="
o_ge:       dsn         ">="
o_ne:       dsn         "<>"

; Forward keyword table: [dsn pointer, tag value], terminated by 0.
kw_tab:     dw          s_rem,    #200000000
            dw          s_print,  #210000000
            dw          s_let,    #220000000
            dw          s_goto,   #230000000
            dw          s_if,     #240000000
            dw          s_then,   #250000000
            dw          s_end,    #260000000
            dw          s_run,    #270000000
            dw          s_list,   #280000000
            dw          s_new,    #290000000
            dw          s_gosub,  #2A0000000
            dw          s_return, #2B0000000
            dw          s_stop,   #2C0000000
            dw          s_poke,   #2D0000000
            dw          s_for,    #2E0000000
            dw          s_next,   #2F0000000
            dw          s_to,     #300000000
            dw          s_step,   #310000000
            dw          s_input,  #320000000
            dw          s_peek,   #400000000
            dw          s_abs,    #410000000
            dw          s_sgn,    #420000000
            dw          s_rnd,    #430000000
            dw          s_int,    #440000000
            dw          0, 0

; Single-char operator table: [char code, tag value], terminated by 0.
optab:      dw          43, #100000000
            dw          45, #110000000
            dw          42, #120000000
            dw          47, #130000000
            dw          40, #140000000
            dw          41, #150000000
            dw          44, #160000000
            dw          59, #170000000
            dw          58, #180000000
            dw          61, #190000000
            dw          0, 0

; Reverse table for detok: [tag value, dsn pointer], terminated by 0.
rev_tab:    dw          #100000000, o_plus
            dw          #110000000, o_minus
            dw          #120000000, o_mul
            dw          #130000000, o_div
            dw          #140000000, o_lpar
            dw          #150000000, o_rpar
            dw          #160000000, o_comma
            dw          #170000000, o_semi
            dw          #180000000, o_colon
            dw          #190000000, o_eq
            dw          #1A0000000, o_lt
            dw          #1B0000000, o_gt
            dw          #1C0000000, o_le
            dw          #1D0000000, o_ge
            dw          #1E0000000, o_ne
            dw          #200000000, s_rem
            dw          #210000000, s_print
            dw          #220000000, s_let
            dw          #230000000, s_goto
            dw          #240000000, s_if
            dw          #250000000, s_then
            dw          #260000000, s_end
            dw          #270000000, s_run
            dw          #280000000, s_list
            dw          #290000000, s_new
            dw          #2A0000000, s_gosub
            dw          #2B0000000, s_return
            dw          #2C0000000, s_stop
            dw          #2D0000000, s_poke
            dw          #2E0000000, s_for
            dw          #2F0000000, s_next
            dw          #300000000, s_to
            dw          #310000000, s_step
            dw          #320000000, s_input
            dw          #400000000, s_peek
            dw          #410000000, s_abs
            dw          #420000000, s_sgn
            dw          #430000000, s_rnd
            dw          #440000000, s_int
            dw          0, 0


; ==========================================================================
; Interpreter state (BSS)
; ==========================================================================

memtop:     bss         1                ; RAM size (first nonexistent word)
varbot:     bss         1                ; bottom of variable table
progend:    bss         1                ; end of program text
runflag:    bss         1                ; nonzero while a program is running
cur_line:   bss         1                ; current line during RUN
jumped:     bss         1                ; set by GOTO/GOSUB to suppress advance
gosub_sp:   bss         1                ; gosub stack pointer
gosub_st:   bss         32               ; gosub return-address stack
for_sp:     bss         1                ; FOR stack pointer (frame index)
for_st:     bss         64               ; FOR stack (4 words/frame)

; I/O interrupt state
out_ptr:    bss         1
out_cnt:    bss         1
out_actv:   bss         1
out_done:   bss         1
inp_rdy:    bss         1
th_ac:      bss         1
th_x2:      bss         1
th_x3:      bss         1

; Tokenizer state
tk_src:     bss         1                ; current source pointer
tk_send:    bss         1                ; source end pointer
tk_dst:     bss         1                ; current dest pointer (into tokbuf)

; Buffers
linemax:    dw          120
linelen:    bss         1
linebuf:    bss         120              ; raw input line (word-per-char)
tokbuf:     bss         300              ; tokenized statement
outexp:     bss         256              ; io_puts expansion scratch

; String heap (bump-allocated; reset on NEW)
strnext:    bss         1
strend:     bss         1
strheap:    bss         4096
